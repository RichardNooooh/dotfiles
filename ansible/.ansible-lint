---
# Ansible-lint configuration for dotfiles project
# Based on Ansible best practices and Red Hat COP standards

# List of rules to skip
skip_list:
  # Skip command-instead-of-module for complex shell operations
  - command-instead-of-shell
  # Skip risky-shell-perm as we use proper permissions
  - risky-shell-perm
  # Skip no-changed-when for shell tasks that are idempotent by nature
  - no-changed-when
  # Skip deprecated-local-action as we don't use it
  - deprecated-local-action
  # Skip name casing rule to allow lowercase task names (e.g., "role | task name")
  - name[casing]
  # Skip command-instead-of-module for curl-to-shell installers (common pattern)
  - command-instead-of-module

# List of additional rules to enable (from community)
enable_list:
  - fqcn
  - yaml

# Exclude these paths from linting
exclude_paths:
  - .cache/
  - .git/
  - .github/
  - .molecule/
  - .tox/
  - venv/
  - ansible/roles/*/molecule/

# Mock modules to avoid false positives for custom modules
mock_modules:
  - community.general.zypper
  - community.general.zypper_repository

# Mock roles for dependency checking
mock_roles:
  - common
  - fonts
  - mise
  - uv
  - shell
  - dotfiles
  - neovim
